# Copia este archivo a .env y completa los valores reales.
# El archivo .env está ignorado por .gitignore — nunca lo commitees.

# AWS
AWS_REGION=us-east-1
AWS_PROFILE=cristian-dev
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# Anthropic
ANTHROPIC_API_KEY=

# GitHub (token scoped al repo del agente)
GITHUB_TOKEN=
GITHUB_REPO=CristianCaro-portfolio/spark-self-heal

# Agente
AGENT_MODE=propose
