# Copy this file to .env and fill in the real values.
# The .env file is ignored by .gitignore - never commit it.

# Anthropic API key for the diagnostic agent.
# Get it from https://console.anthropic.com -> Settings -> API Keys.
ANTHROPIC_API_KEY=sk-ant-api03-xxx

# Model used by the agent. Override if you want to test a different one.
ANTHROPIC_MODEL=claude-sonnet-4-5

# AWS profile and region used by boto3 inside the agent tools and by the
# Airflow DAG that triggers the Glue Job. Match an existing profile in
# ~/.aws/credentials.
AWS_PROFILE=spark-self-heal
AWS_DEFAULT_REGION=us-east-1

# GitHub fine-grained personal access token, scoped to a single repo.
# Required permissions on the repo:
#   - Contents:      Read and write   (push branches with the agent's patches)
#   - Pull requests: Read and write   (open PRs from the agent)
#   - Workflows:     Read and write   (let the agent touch .github/workflows)
#   - Metadata:      Read             (default, cannot be removed)
# Token format starts with `github_pat_` (fine-grained), NOT `ghp_` (classic).
GITHUB_TOKEN=github_pat_xxx
GITHUB_REPO=CristianCaro-portfolio/spark-self-heal

# Agent autonomy mode (see docs/adr/002-agent-autonomy-scope.md).
#   observe - read logs and diagnose only, no patch, no PR
#   propose - diagnose + write a patch under agent/patches/ + open a PR
#   apply   - propose mode, plus auto-merge if CI passes (requires
#             --allow-auto-merge flag on the command line)
AGENT_MODE=propose
