# Copy this file to .env and fill in the real values.
# The .env file is ignored by .gitignore — never commit it.

# AWS
AWS_REGION=us-east-1
AWS_PROFILE=cristian-dev
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# Anthropic
ANTHROPIC_API_KEY=

# GitHub (token scoped to the agent's repo)
GITHUB_TOKEN=
GITHUB_REPO=CristianCaro-portfolio/spark-self-heal

# Agent
AGENT_MODE=propose
